# 灵析学习平台 - 环境变量配置
# 将此文件复制为 .env 并填入真实值，然后启动服务

# ---- 讯飞 Spark AI ----
SPARK_APP_ID=你的APPID
SPARK_API_SECRET=你的APISecret
SPARK_API_KEY=你的APIKey

# ---- 讯飞 MaaS Qwen 模型（群聊解题） ----
QWEN_API_KEY=你的QwenAPIKey
QWEN_API_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2/chat/completions
QWEN_MODEL=xop3qwen1b7

# ---- 讯飞翻译服务 ----
TRANSLATE_API_KEY=你的翻译APIKey

# ---- DeepSeek API（可选） ----
DEEPSEEK_API_KEY=你的DeepSeekAPIKey

# ---- QQ邮箱 SMTP（注册验证码） ----
SMTP_USER=你的QQ邮箱地址
SMTP_PASS=你的QQ邮箱授权码

# ---- JDoodle 代码执行沙箱 ----
JDOODLE_CLIENT_ID=你的JDoodleClientID
JDOODLE_CLIENT_SECRET=你的JDoodleClientSecret

# ---- 管理员账号（首次初始化时使用） ----
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@lingxi.com
ADMIN_PASSWORD=你的管理员密码

# ---- Flask 调试模式（生产环境请保持为 0） ----
FLASK_DEBUG=0
